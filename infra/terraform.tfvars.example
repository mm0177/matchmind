# ─── terraform.tfvars example ─────────────────────────────────────────────────
# Copy this to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to git (it contains your RDS password).
#
# Usage:
#   terraform plan  -var-file="terraform.tfvars"
#   terraform apply -var-file="terraform.tfvars"

aws_region         = "ap-southeast-2"
project_name       = "matchmind"
ec2_instance_type  = "t3.medium"
ec2_key_pair_name  = "matchmind"   # Must exist in your AWS account
rds_instance_class = "db.t4g.micro"
rds_db_name        = "matchmaking"
rds_username       = "matchmind_user"
rds_password       = "Mkarthik#12"
my_ip              = "157.51.116.137/32"           # e.g. "203.0.113.50/32" — find at whatismyip.com
