# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=MatchMind
DEBUG=false
SECRET_KEY=change-this-to-a-long-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ─── Clerk Auth ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=public_test_...
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=matchmind_api
CLERK_SECRET_KEY=secret_test_...
CLERK_ISSUER=https://example.clerk.accounts.dev
CLERK_JWKS_URL=https://example.clerk.accounts.dev/.well-known/jwks.json
CLERK_AUDIENCE=matchmind-api
CLERK_JWT_TEMPLATE=matchmind_api

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/matchmaking

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Choose one: groq | openai | anthropic | gemini
LLM_PROVIDER=groq

# Groq — Llama 3.3 70B (fast, free tier available)
GROQ_API_KEY=gsk_your_groq_api_key_here

GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_EXTRACTION_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EXTRACTION_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_EXTRACTION_MODEL=claude-3-5-sonnet-20241022

GEMINI_API_KEY=AIza_hidden
GEMINI_CHAT_MODEL=gemini-1.5-pro
GEMINI_EXTRACTION_MODEL=gemini-1.5-pro

# ─── Embeddings (local via LM Studio) ────────────────────────────────────────
# 1. In LM Studio: load bge-small-en-v1.5-gguf → enable local server on port 1234
# 2. The API identifier shown in LM Studio: text-embedding-bge-small-en-v1.5
EMBEDDING_PROVIDER=lmstudio
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_EMBEDDING_MODEL=text-embedding-bge-small-en-v1.5
EMBEDDING_DIM=384

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SENDGRID_KEY_...
EMAIL_FROM=noreply@matchmind.app
EMAIL_FROM_NAME=MatchMind

# ─── Matching thresholds ──────────────────────────────────────────────────────
MIN_DAYS_FOR_MATCHING=7
MIN_PERSONA_CONFIDENCE=0.5
MIN_MATCH_SCORE=0.60

# Dev/testing — set to false for production
DEV_MODE=true
